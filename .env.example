# Django Settings
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/airtasker_db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# AWS S3 (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Cloudinary (Optional — https://cloudinary.com/)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Unsigned upload preset (Settings → Upload → Upload presets → enable "Unsigned")
CLOUDINARY_UPLOAD_PRESET=
# Parent folder for all Cloudinary assets (e.g. Sajilowork/Users/Profiles).
# Set the same root on your unsigned upload preset in Cloudinary Console.
CLOUDINARY_DEFAULT_FOLDER=Sajilowork
# Only set true after API key has upload/create permission in Cloudinary Console → API Keys
CLOUDINARY_USE_DEFAULT_STORAGE=false

# Khalti Payment (Nepal)
KHALTI_PUBLIC_KEY=
KHALTI_SECRET_KEY=

# eSewa Payment (Nepal)
ESEWA_MERCHANT_ID=
ESEWA_SECRET_KEY=

# Escrow — auto-release funds after customer approval window (hours)
ESCROW_AUTO_RELEASE_HOURS=48

# Manual wallet recharge — admin WhatsApp (country code + number, digits only)
RECHARGE_WHATSAPP_NUMBER=97798XXXXXXXX

# Sentry (Error Tracking)
SENTRY_DSN=

# Google OAuth — create a "Web application" client at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match "Authorized redirect URIs" in Google Cloud Console:
#   Local:  http://localhost:8000/api/v1/auth/google/callback/
#   Prod:   https://sajiloworkbackend.everacy.com/api/v1/auth/google/callback/
# JavaScript origins in Google Console (not redirect URIs):
#   Local:  http://localhost:3000
#   Prod:   https://www.sajilowork.com
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback/

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Twilio (SMS/Phone Verification)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Frontend URL (OAuth success redirect, email links)
FRONTEND_URL=http://localhost:3000
# Production: https://www.sajilowork.com

# Backend public URL (OAuth redirect URIs — must match Google app settings)
BACKEND_URL=http://localhost:8000
# Production: https://sajiloworkbackend.everacy.com
# Google authorized redirect URI: {BACKEND_URL}/api/v1/auth/google/callback/
# Facebook valid OAuth redirect URI: {BACKEND_URL}/api/v1/auth/facebook/callback/

# SMS Gateway Configuration (Nepal)
# Popular options: Sparrow SMS (https://sparrowsms.com), Aakash SMS, SMS Nepal
SMS_GATEWAY_URL=
SMS_GATEWAY_TOKEN=

# API Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
